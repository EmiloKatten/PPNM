set terminal svg background rgb "white"
set output "error.svg"
set xlabel "N"
set ylabel "error"
set key right top
set logscale xy
set tics out
plot \
	 "data_error.txt" using 1:2 with lines title "pseudo-random est. error",\
	 "data_error.txt" using 1:3 with lines title "pseudo-random act. error",\
	 "data_error.txt" using 1:4 with lines title "1/sqrt(N)",\
	 "quasi_error.txt" using 1:2 with lines title "quasi-random act. error"\
