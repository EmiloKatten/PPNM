set terminal svg background rgb "white"
set output "comp_timing.svg"
set title "Timing Newton Rootfinding" font ",18"
set xlabel "Symmetric Matrix of Size n" font ",14"
set ylabel "Time (s)" font ",14"
set key left top
set tics out

plot \
     "comp_timing.data" using 1:2 with lines title "Newton" lw 2,\
     "comp_timing.data" using 1:3 with lines title "EVD" lw 2,

